# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path (relative to project root)
DB_PATH=./data/la2eny.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Simple API-key guard for write endpoints (optional in dev)
API_SECRET=change_me_in_production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (* = all)
CORS_ORIGINS=*

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
